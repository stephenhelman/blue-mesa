# ---------------------------------------------------------------------------
# Blue Mesa Pools & Spas — environment
# Copy to `.env.local` for local dev, and set the same vars in Vercel.
# ---------------------------------------------------------------------------

# Google Apps Script web-app URL that receives consultation leads and appends
# a row to the Google Sheet. Server-side only (never exposed to the browser).
#
# Stand up the Sheet + Apps Script first (see docs/google-apps-script.md),
# deploy it as a web app, then paste the /exec URL here.
#
# Until this is set, the form returns a friendly "please call us" error.
LEADS_WEBHOOK_URL=
